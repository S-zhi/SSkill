# ============================================================
# Coze 抖音 ASR 抓取所需配置
# 使用方法：把本文件复制为 .env（去掉 .example 后缀），填入下方值。
#   cp assets/.env.example .env
# 注意：.env 含密钥，切勿提交到 git。
# ============================================================

# Coze 个人访问令牌（Personal Access Token）
# 获取路径：Coze 平台 -> 个人设置 -> API 授权 -> 个人访问令牌
COZE_Personal_Access_Token=

# 默认抖音解析工作流 ID（从工作流网页链接末尾获取，可选）
# 若填写，运行时可省略 --workflow-id
COZE_WORKFLOW_ID=
